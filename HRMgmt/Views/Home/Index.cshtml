@{
    ViewData["Title"] = "Home";
    var userName = Context.Session.GetString("UserName");
}

<section class="hero-section">

    @if (!string.IsNullOrEmpty(userName))
    {
        <!-- Login status -->
        <div class="welcome-only">
            <h1>Welcome back, @userName</h1>
        </div>
    }
    else
    {
        <!-- Logout status -->
        <section class="landing-center">
            <h1>HR Management</h1>

            <p>
                Internal system for managing employee schedules, payroll,
                and organizational records.
            </p>

            <div class="landing-login-row">
                <a class="btn btn-primary landing-login-btn"
                   asp-controller="Account"
                   asp-action="Login">
                    Login
                </a>
            </div>
        </section>
    }

</section>