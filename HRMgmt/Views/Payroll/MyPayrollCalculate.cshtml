@model HRMgmt.ViewModels.AdminPayrollCalcViewModel

@{
    ViewData["Title"] = "My Payroll Calculation";
}

<h2>My Payroll Calculation</h2>

<form asp-action="MyPayrollCalculate" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <div class="col-md-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" type="date" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" type="date" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="col-md-3 align-self-end">
        <button type="submit" class="btn btn-primary">Calculate</button>
    </div>

    <div class="col-12">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div class="text-danger">@err.ErrorMessage</div>
        }
    </div>
</form>

@if (Model.Rows != null && Model.Rows.Count > 0)
{
    <hr />
    <h4>Results</h4>

    <div class="mb-2">
        <strong>Total Hours:</strong> @Model.TotalHoursAllEmployees<br />
        <strong>Total Gross:</strong> @Model.TotalGrossAllEmployees<br />
        <strong>Total Pension:</strong> @Model.TotalPensionAllEmployees<br />
        <strong>Total Tax:</strong> @Model.TotalTaxAllEmployees<br />
        <strong>Total Net:</strong> @Model.TotalNetAllEmployees
    </div>


    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Hourly Wage</th>
                <th>Shift Count</th>
                <th>Total Hours</th>
                <th>Gross Pay</th>
                <th>Pension (5%)</th>
                <th>Tax (20%)</th>
                <th>Net Pay</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Rows)
            {
                <tr>
                    <td>@r.EmployeeName</td>
                    <td>@r.HourlyWage</td>
                    <td>@r.ShiftCount</td>
                    <td>@r.TotalHours</td>
                    <td>@r.GrossPay</td>
                    <td>@r.PensionDeduction</td>
                    <td>@r.TaxDeduction</td>
                    <td><strong>@r.NetPay</strong></td>
                </tr>
            }
        </tbody>
    </table>
}

