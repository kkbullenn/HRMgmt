@model IEnumerable<HRMgmt.Models.Payroll>

@{
    ViewData["Title"] = "My Payroll";
}

<h2>My Payroll</h2>

@if (Model == null || !Model.Any())
{
    <p>No payroll records found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Pay Period Start</th>
                <th>Pay Period End</th>
                <th>Regular Hours</th>
                <th>Overtime Hours</th>
                <th>Sick Hours</th>
                <th>Total Hours</th>
                <th>Gross Pay</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.PayPeriodStart.ToString("yyyy-MM-dd")</td>
                    <td>@p.PayPeriodEnd.ToString("yyyy-MM-dd")</td>
                    <td>@p.RegularHours</td>
                    <td>@p.OvertimeHours</td>
                    <td>@p.SickHours</td>
                    <td>@p.TotalHours</td>
                    <td>@p.GrossPay</td>
                    <td>@p.Status</td>
                    <td>@p.CreatedDate.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
}
