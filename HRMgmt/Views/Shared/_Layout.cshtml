<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRMgmt</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HRMgmt.styles.css" asp-append-version="true" />
</head>

<body>
    <div class="app-shell">

        <header class="pill-nav">
            @{
                var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
                var actionName = ViewContext.RouteData.Values["action"]?.ToString();

                // Use Session as a secondary check to ensure the UI stays hidden
                var isUserLoggedIn = User.Identity?.IsAuthenticated == true &&
                !string.IsNullOrEmpty(Context.Session.GetString("UserId"));

                var isHome = controllerName == "Home" && actionName == "Index";
                var isLoginPage = controllerName == "Account" && actionName == "Login";
            }

            @if (isLoginPage || !isUserLoggedIn)
            {
                <a class="brand-pill" asp-controller="Home" asp-action="Index">HRMgmt</a>
            }

            @if (isUserLoggedIn)
            {
                <nav class="nav-pills">
                    @* Back Arrow - only if not on Home *@
                    @if (!isHome)
                    {
                        <a asp-controller="Home" asp-action="Index" class="back-pill" title="Back to Home">←</a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                    {
                        <a class="nav-pill @(controllerName == "Users" ? "active" : "")"
                           asp-controller="Users" asp-action="Index">People</a>

                        <a class="nav-pill @(controllerName == "Shift" ? "active" : "")"
                           asp-controller="Shift" asp-action="Index">Shifts</a>

                        <a class="nav-pill @(controllerName == "Payroll" ? "active" : "")"
                           asp-controller="Payroll" asp-action="Index">Payroll</a>
                    }
                </nav>
            }

            <div class="nav-actions">
                @if (isUserLoggedIn)
                {
                    <div class="user-pill">
                        <span class="user-pill-name">Hello, @User.Identity.Name!</span>
                        <a class="user-pill-link" asp-controller="Account" asp-action="Logout">Logout</a>
                    </div>
                }
            </div>
        </header>


        <main class="page">
            @RenderBody()
        </main>

        <footer class="shell-footer">
            <div>
                &copy; 2026 - HRMgmt -
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>  
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>