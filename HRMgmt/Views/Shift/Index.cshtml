@model IEnumerable<HRMgmt.Models.Shift>
@{
    ViewData["Title"] = "Shift List";
    var hasShifts = Model?.Any() == true;
}

<div class="d-flex align-items-center justify-content-between" style="margin-bottom: 12px;">
    <div>
        <h1 style="margin:0; font-weight:800;">Shift List</h1>
        <div style="color: var(--text-muted); margin-top: 4px;">All shift types in the system</div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-action="Create">Create Shift</a>

        @if (hasShifts)
        {
            <a class="btn btn-success" asp-controller="Shift" asp-action="ShiftAssignment">Next: Assign Schedule</a>
        }
        else
        {
            <button class="btn btn-success" type="button" disabled>Next: Assign Schedule</button>
        }
    </div>
</div>

@if (!hasShifts)
{
    <div class="ui-card">
        <div style="font-weight:800; font-size:1.1rem;">No shifts yet</div>
        <div style="color: var(--text-muted); margin-top:6px;">
            Create at least one shift to start assigning schedules.
        </div>
    </div>
}
else
{
    <div class="shift-list">
        @foreach (var item in Model)
        {
            <a class="shift-card"
               asp-action="Details"
               asp-route-id="@item.ShiftId">
                <div class="shift-card-left">
                    <div class="shift-title">@item.Name</div>

                    <div class="shift-meta">
                        <span class="shift-chip">
                            @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                        </span>

                        <span class="shift-chip">
                            Required: @item.RequiredCount
                        </span>

                        <span class="shift-chip">
                            @item.StartDate.ToString("yyyy-MM-dd") → @item.EndDate.ToString("yyyy-MM-dd")
                        </span>
                    </div>

                    <div class="shift-sub">Click to view details</div>
                </div>

            </a>
        }
    </div>
}

<div class="mt-4" style="display:none;">
    <button class="btn btn-success" onclick="autoGenerateSchedule()">Auto Assign Bi-weekly Shifts</button>
</div>

<script>
    function autoGenerateSchedule() {
        const startDate = prompt('Please enter the start date for scheduling (yyyy-MM-dd):', new Date().toISOString().slice(0,10));
        if (!startDate) return;
        fetch('/Shift/AutoGenerateSchedule', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ startDate: startDate, days: 14 })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert('Shifts generated successfully! Total: ' + data.count + ' records');
            } else {
                alert('Failed to generate shifts: ' + (data.message || 'Unknown error'));
            }
        })
        .catch(e => alert('Request failed: ' + e));
    }
</script>