@model HRMgmt.Models.Shift

@{
    ViewData["Title"] = "Delete Shift";
}

<h2>Delete Shift</h2>
<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>@Model.Name</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Start Time</dt>
        <dd class="col-sm-10">@Model.StartTime</dd>
        <dt class="col-sm-2">End Time</dt>
        <dd class="col-sm-10">@Model.EndTime</dd>
        <dt class="col-sm-2">Required Count</dt>
        <dd class="col-sm-10">@Model.RequiredCount</dd>
        <dt class="col-sm-2">Start Date</dt>
        <dd class="col-sm-10">@Model.StartDate.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-2">End Date</dt>
        <dd class="col-sm-10">@Model.EndDate.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-2">Recurrence Type</dt>
        <dd class="col-sm-10">@Model.RecurrenceType</dd>
        <dt class="col-sm-2">Recurrence Days</dt>
        <dd class="col-sm-10">@Model.RecurrenceDays</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ShiftId" />
        <input type="submit" class="btn btn-danger" value="Delete" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
