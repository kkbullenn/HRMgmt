@model HRMgmt.Models.Shift

@{
    ViewData["Title"] = "Shift Details";
}

<div class="d-flex justify-content-between align-items-start" style="margin-bottom:12px;">
    <div>
        <h1 style="margin:0; font-weight:800;">@Model.Name</h1>
        <div style="color: var(--text-muted); margin-top:4px;">
            Shift details and configuration
        </div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.ShiftId">Edit</a>
        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.ShiftId">Delete</a>
    </div>
</div>

<div class="ui-card">
    <div class="shift-details-grid">
        <div class="shift-details-item">
            <div class="shift-details-label">Start Time</div>
            <div class="shift-details-value">@Model.StartTime.ToString(@"hh\:mm")</div>
        </div>

        <div class="shift-details-item">
            <div class="shift-details-label">End Time</div>
            <div class="shift-details-value">@Model.EndTime.ToString(@"hh\:mm")</div>
        </div>

        <div class="shift-details-item">
            <div class="shift-details-label">Required Count</div>
            <div class="shift-details-value">@Model.RequiredCount</div>
        </div>

        <div class="shift-details-item">
            <div class="shift-details-label">Start Date</div>
            <div class="shift-details-value">@Model.StartDate.ToString("yyyy-MM-dd")</div>
        </div>

        <div class="shift-details-item">
            <div class="shift-details-label">End Date</div>
            <div class="shift-details-value">@Model.EndDate.ToString("yyyy-MM-dd")</div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <a class="btn btn-outline-secondary" asp-action="Index">Back to List</a>
    </div>
</div>