@{
    ViewData["Title"] = "Employee Shift Calendar";
}
<h2>Employee Shift Calendar</h2>
<div class="form-group mb-3">
    <label for="employeeSelect">Select Employee:</label>
    <select id="employeeSelect" class="form-control" style="max-width:300px;display:inline-block"></select>
</div>
<div id="calendar"></div>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
<style>
    .fc-daygrid-day-events {
        overflow: visible !important;
        position: relative !important;
    }
    .fc-daygrid-event-harness,
    .fc-daygrid-event-dot,
    .fc-daygrid-event {
        border: none !important;
        box-shadow: none !important;
        background: none !important;
    }
    .fc-daygrid-event-harness {
        border-top: none !important;
    }
    .fc-daygrid-event-dot {
        display: none !important;
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var calendarEl = document.getElementById('calendar');
    var employeeSelect = document.getElementById('employeeSelect');
    var currentEmployeeId = null;

    // Load employee list
    fetch('/Shifts/GetEmployees')
        .then(r => r.json())
        .then(data => {
            data.forEach(emp => {
                var opt = document.createElement('option');
                opt.value = emp.id;
                opt.text = emp.name;
                employeeSelect.appendChild(opt);
            });
            if (data.length > 0) {
                currentEmployeeId = data[0].id;
                initCalendar();
            }
        });

    employeeSelect.addEventListener('change', function() {
        currentEmployeeId = this.value;
        if (calendar) {
            calendar.setOption('events', '/Shifts/GetEmployeeShifts?employeeId=' + currentEmployeeId);
            calendar.refetchEvents();
        }
    });

    var calendar = null;
    function initCalendar() {
        calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            editable: true,
            selectable: true,
            events: '/Shifts/GetEmployeeShifts?employeeId=' + currentEmployeeId,
            eventContent: function(arg) {
                let shiftName = arg.event.title.split(' ')[0].toLowerCase();
                let color = '';
                let top = '';
                if (shiftName.includes('morning')) {
                    color = '#ffe066'; 
                    top = '0px';
                } else if (shiftName.includes('evening')) {
                    color = '#b2f7b2'; 
                    top = '22px';
                } else if (shiftName.includes('night')) {
                    color = '#a0c4ff'; 
                    top = '44px';
                }
                return {
                    html: `<div style="position:absolute;left:0;right:0;top:${top};background:${color};border-radius:4px;padding:2px 4px;margin:0;font-size:13px;z-index:2;">${arg.event.title}</div>`
                };
            },
            eventDidMount: function(info) {
                if (info.el.parentElement) {
                    info.el.parentElement.style.position = 'relative';
                    info.el.style.position = 'static';
                }
            },
            dateClick: function(info) {
                let oldDropdown = document.getElementById('shiftDropdown');
                if (oldDropdown) oldDropdown.remove();
                let dropdown = document.createElement('select');
                dropdown.id = 'shiftDropdown';
                dropdown.className = 'form-control';
                dropdown.style.position = 'absolute';
                dropdown.style.zIndex = 9999;
                dropdown.style.width = '240px';
                dropdown.style.maxWidth = '300px';
                dropdown.style.minWidth = '120px';
                let cell = info.dayEl;
                let rect = cell.getBoundingClientRect();
                dropdown.style.left = rect.left + window.scrollX + 'px';
                dropdown.style.top = rect.top + window.scrollY + 'px';
                let defaultOpt = document.createElement('option');
                defaultOpt.value = '';
                defaultOpt.text = 'Select shift template';
                dropdown.appendChild(defaultOpt);
                fetch('/Shifts/GetShifts')
                    .then(r => r.json())
                    .then(shifts => {
                        shifts.forEach(s => {
                            let opt = document.createElement('option');
                            opt.value = s.id;
                            opt.text = s.title + ' ' + s.start + '-' + s.end + ' ' + s.location;
                            dropdown.appendChild(opt);
                        });
                    });
                dropdown.addEventListener('change', function() {
                    if (this.value) {
                        fetch('/Shifts/AssignShift', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                employeeId: currentEmployeeId,
                                shiftId: this.value,
                                date: info.dateStr
                            })
                        })
                        .then(r => r.json())
                        .then(res => {
                            if (res.success) {
                                alert('Shift assigned successfully!');
                                if (calendar) calendar.refetchEvents();
                            } else {
                                alert('Assignment failed: ' + res.message);
                            }
                        })
                        .catch(err => {
                            alert('Request error: ' + err);
                        });
                        dropdown.remove();
                    }
                });
                document.addEventListener('click', function handler(e) {
                    if (e.target !== dropdown) {
                        dropdown.remove();
                        document.removeEventListener('click', handler);
                    }
                });
                document.body.appendChild(dropdown);
            },
            eventClick: function(info) {
                if (confirm('Delete this shift assignment?')) {
                    fetch('/Shifts/DeleteEmployeeShift', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            employeeId: currentEmployeeId,
                            shiftId: info.event.id,
                            date: info.event.startStr
                        })
                    })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) {
                            alert('Deleted successfully!');
                            if (calendar) calendar.refetchEvents();
                        } else {
                            alert('Delete failed: ' + res.message);
                        }
                    })
                    .catch(err => {
                        alert('Request error: ' + err);
                    });
                }
            },
        });
        calendar.render();
    }
});
</script>
